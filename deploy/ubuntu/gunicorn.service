[Unit]
Description=Gunicorn service for Thesis Django project
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/thesis/backend
EnvironmentFile=/var/www/thesis/backend/.env
ExecStart=/var/www/thesis/.venv/bin/gunicorn backend.wsgi:application --workers 3 --bind unix:/run/gunicorn-thesis.sock --timeout 300
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
